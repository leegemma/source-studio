OPENAI_API_KEY=""

# 배포된 사이트 전체를 보호하는 간단한 비밀번호 게이트.
# 비워두면(로컬 개발 등) 게이트가 자동으로 꺼짐.
SITE_PASSWORD=""

# auto-edit-backend(Flask)가 실제로 떠 있는 주소. 비워두면 기본값
# http://localhost:5050 사용 -- 로컬 개발에서는 보통 그대로 두면 됨.
# next.config.js의 rewrites()가 /api/auto-edit/*를 여기로 서버측 전달하므로,
# 브라우저는 항상 같은 출처로만 호출하고 이 값은 Next.js 서버만 읽는다
# (NEXT_PUBLIC_ 접두사가 없어 클라이언트 번들에는 포함되지 않음).
AUTO_EDIT_BACKEND_URL=""
